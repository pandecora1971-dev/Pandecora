# ─── Database ─────────────────────────────────────────────────────────────────
# Inside Docker Compose the host is "db"; outside (local dev) use "localhost"
DATABASE_URL="postgresql://admin:secret123@db:5432/incidentdb"

# Separate vars consumed by docker-compose.yml environment block
DB_USER=admin
DB_PASSWORD=secret123
DB_NAME=incidentdb

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"
# Pepper for HMAC-SHA256 email hashing — generate with: openssl rand -hex 32
HASH_PEPPER="generate-with-openssl-rand-hex-32"

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Admin seed credentials ───────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-strong-password"

# ─── Storage ──────────────────────────────────────────────────────────────────
# "local" uses ./uploads on disk; "r2" uses Cloudflare R2
STORAGE_ADAPTER="local"

# Cloudflare R2 (only required when STORAGE_ADAPTER=r2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
